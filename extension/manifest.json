{
    "manifest_version": 3,
    "name": "Tree Detector",
    "version": "1.0",
    "description": "Detects Trees in OSM for quick tree plotting",
    "permissions": ["tabs", "storage"],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Tree Detector",
        "default_icon": {
            "16": "assets/icon16.png",
            "32": "assets/icon16.png",
            "128": "assets/icon16.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["https://www.openstreetmap.org/edit*"],
            "js": ["Content.js"]
        }
    ]
}
